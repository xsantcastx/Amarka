Thumbs.db

# Environment files - Only ignore .env files, not Angular environment.ts
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Firebase project configuration (users should copy .firebaserc.example)
.firebaserc

# Template-generated config
src/config-loader/generated/
src/environments/environment.generated.ts
# Angular environment files are safe to commit (Firebase keys are public anyway)
# Uncomment these if you want to use environment variables in CI/CD instead:
# src/environments/environment.ts
# src/environments/environment.prod.ts
.trash/

# AMK-26 Phase 2: orphaned legacy storefront files.
# These paths were removed from git tracking in commit e8c2a38 but their
# working-tree copies persist (the scheduled sandbox lacks delete permission
# on the workspace mount, so prior runs could only untrack, not purge).
# They are excluded from tsconfig.app.json + tsconfig.spec.json compilation
# and ignored here so `git status` and Angular builds stay clean.
# If you clone fresh, these directories will not be recreated.
src/app/features/contacto/
src/app/features/datos-tecnicos/
src/app/features/galeria/
src/app/features/productos/
src/app/features/home/colecciones-destacadas/
src/app/pages/contacto/
src/app/pages/galeria/
src/app/pages/productos/
src/app/pages/servicios/
src/app/pages/solo-miners/
src/app/pages/home/home.page.scss.bak
src/app/services/gallery.service.ts
src/app/shared/components/cart-button/
src/app/shared/components/product-reviews/
src/app/shared/models/
src/app/shared/services/

# Sandbox write-probe artifacts (harmless, sandbox can't delete)
.amk-write-probe.txt
